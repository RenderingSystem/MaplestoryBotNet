                Margin="405,88,0,0"
                VerticalAlignment="Top"
                Width="43"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Right:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="405,109,0,0"
                VerticalAlignment="Top"
                Width="50"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Bottom:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="405,130,0,0"
                VerticalAlignment="Top"
                Width="55"
                FontSize="10"
                Foreground="White"
                RenderTransformOrigin="0.509,1.614"
            />
            <TextBox
                x:Name="MapAreaBottomTextBox"
                Margin="468,130,10,381"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="3"
            />
            <TextBox
                x:Name="MapAreaRightTextBox"
                Margin="468,109,10,402"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="2"
            />
            <TextBox
                x:Name="MapAreaTopTextBox"
                Margin="468,87,10,424"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="1"
            />
            <TextBox
                x:Name="MapAreaLeftTextBox"
                Margin="468,65,10,446"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="0"
            />
            <Button
                x:Name="SaveButton"
                FontFamily="Courier New"
                Content="Save"
                HorizontalAlignment="Left"
                Margin="99,478,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Foreground="White"
                Background="Black"
                BorderBrush="White"
                Width="160"
                IsTabStop="False"
                Height="27"
            />
            <Button
                x:Name="LoadButton"
                FontFamily="Courier New"
                Content="Load"
                HorizontalAlignment="Left"
                Margin="320,478,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Foreground="White"
                Background="Black"
                BorderBrush="White"
                Width="160"
                IsTabStop="False" Height="26"
            />
        </Grid>
    </Viewbox>
</Window>
