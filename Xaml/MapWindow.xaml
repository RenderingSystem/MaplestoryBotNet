<Window 
    x:Class="MaplestoryBotNet.Xaml.MapWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MaplestoryBotNet.Xaml"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    mc:Ignorable="d"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Title="Map"
    Width="600"
    Height="550"
    MaxHeight="550"
    MaxWidth="600"
    MinHeight="550"
    MinWidth="600"
    Background="Black"
>
    <Viewbox Stretch="Fill">
        <Grid Background="Black" Height="480" Width="575" >
            <Border 
                Width="400"
                Height="400"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="Black"
                BorderBrush="White"
                BorderThickness="1,1,1,1"
            />
            <Grid
                Width="400"
                Height="400"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
            >
                <Image
                    x:Name="MapImage"
                    Width="400"
                    Height="400"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                />
                <Frame Background="#8C000000"/>
            </Grid>
            <Canvas
                x:Name="MapCanvas"
                Width="400"
                Height="400"
                Background="Transparent"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                IsHitTestVisible="True"
                Visibility="Visible"
            />
            <ToggleButton
                x:Name="AddButton"
                FontFamily="Courier New"
                Content="Add point"
                HorizontalAlignment="Left"
                Margin="0,405,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Foreground="White"
                Background="Black"
                BorderBrush="White"
                Width="130"
                IsTabStop="False"
            />
            <ToggleButton
                x:Name="RemoveButton"
                FontFamily="Courier New"
                Content="Remove point"
                HorizontalAlignment="Left"
                Margin="134,405,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Foreground="White"
                Background="Black"
                BorderBrush="White"
                Width="130"
                IsTabStop="False"
            />
            <Button
                x:Name="EditButton"
                FontFamily="Courier New"
                Content="Edit point"
                HorizontalAlignment="Left"
                Margin="269,405,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                IsEnabled="False"
                Width="130"
                IsTabStop="False"
            >
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="Black"
                            BorderBrush="White"
                            BorderThickness="1"
                        >
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"
                                RecognizesAccessKey="True"
                            />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="BorderBrush" Value="Gray"/>
                                <Setter TargetName="border" Property="Background" Value="Black"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="border" Property="Background" Value="Black"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="LightSkyBlue"/>
                                <Setter TargetName="border" Property="Background" Value="#BEE6FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="LightBlue"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button
                x:Name="SaveButton"
                FontFamily="Courier New"
                Content="Save"
                HorizontalAlignment="Left"
                Margin="120,444,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Foreground="White"
                Background="Black"
                BorderBrush="White"
                Width="160"
                IsTabStop="False" Height="27"
            />
            <Button
                x:Name="LoadButton"
                FontFamily="Courier New"
                Content="Load"
                HorizontalAlignment="Left"
                Margin="298,444,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Foreground="White"
                Background="Black"
                BorderBrush="White"
                Width="160"
                IsTabStop="False" Height="26"
            />
            <Label
                Content="Point selected:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="404,120,0,0"
                VerticalAlignment="Top"
                Width="180"
                Foreground="White"
                FontSize="10"
            />
            <Label
                Content="Point location:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="405,163,0,0"
                VerticalAlignment="Top"
                Width="120"
                Foreground="White"
                FontSize="10"
            />
            <Label
                Content="Map Area:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="405,10,0,0"
                VerticalAlignment="Top"
                Width="69"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Left:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,31,0,0"
                VerticalAlignment="Top"
                Width="41"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Top:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,52,0,0"
                VerticalAlignment="Top"
                Width="41"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Right:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,73,0,0"
                VerticalAlignment="Top"
                Width="47"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Bottom:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,94,0,0"
                VerticalAlignment="Top"
                Width="52"
                FontSize="10"
                Foreground="White"
                RenderTransformOrigin="0.509,1.614"
            />
            <TextBox
                x:Name="MapAreaBottomTextBox"
                Margin="464,96,10,365"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="3"
            />
            <TextBox
                x:Name="MapAreaRightTextBox"
                Margin="464,75,10,385"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="2"
            />
            <TextBox
                x:Name="MapAreaTopTextBox"
                Margin="464,53,10,407"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="1"
            />
            <TextBox
                x:Name="MapAreaLeftTextBox"
                Margin="464,31,10,428"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="0"
            />
            <TextBox
                x:Name="LocationTextBoxX"
                Margin="464,187,10,272"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="5"
            />
            <Label
                Content="X:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,187,0,0"
                VerticalAlignment="Top"
                Width="24"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="LocationTextBoxY"
                Margin="464,209,10,251"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="6"
            />
            <Label
                Content="Y:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,208,0,0"
                VerticalAlignment="Top"
                Width="24"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="LabelTextBox"
                Margin="464,143,10,317"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                TabIndex="4"
                IsReadOnly="True"
            />
            <Label
                Content="Label:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,141,0,0"
                VerticalAlignment="Top"
                Width="45"
                FontSize="10"
                Foreground="White"
                RenderTransformOrigin="0.509,1.614"
            />
            <Label
                Content="Character:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="405,228,0,0"
                VerticalAlignment="Top"
                Width="69"
                Foreground="White"
                FontSize="10"
            />
            <TextBox
                x:Name="CharacterTextBoxX"
                Margin="464,247,10,213"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                TabIndex="7"
                IsReadOnly="True"
            />
            <Label
                Content="X:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,247,0,0"
                VerticalAlignment="Top"
                Width="24"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="CharacterTextBoxY"
                Margin="464,268,10,192"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                TabIndex="8"
                IsReadOnly="True"
            />
            <Label
                Content="Y:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,267,0,0"
                VerticalAlignment="Top"
                Width="24"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Rune:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="405,311,0,0"
                VerticalAlignment="Top"
                Width="69"
                Foreground="White"
                FontSize="10"
            />
            <TextBox
                x:Name="RuneTextBoxX"
                Margin="464,330,10,130"
                Background="Black"
                Foreground="Violet"
                FontFamily="Courier New"
                TabIndex="10"
                IsReadOnly="True"
            />
            <Label
                Content="X:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,330,0,0"
                VerticalAlignment="Top"
                Width="24"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="RuneTextBoxY"
                Margin="464,352,10,108"
                Background="Black"
                Foreground="Violet"
                FontFamily="Courier New"
                TabIndex="11"
                IsReadOnly="True"
            />
            <Label
                Content="Y:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,350,0,0"
                VerticalAlignment="Top"
                Width="24"
                FontSize="10"
                Foreground="White"
            />
            <Label Content="Limit:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,288,0,0"
                VerticalAlignment="Top"
                Width="45"
                FontSize="10"
                Foreground="White"
          />
            <TextBox
                x:Name="CharacterThreshold"
                Margin="464,289,10,171"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="9"
            />
            <Label Content="Limit:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="412,372,0,0"
                VerticalAlignment="Top"
                Width="45"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="RuneThreshold"
                Margin="464,373,10,87"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="12"
            />
        </Grid>
    </Viewbox>
</Window>
