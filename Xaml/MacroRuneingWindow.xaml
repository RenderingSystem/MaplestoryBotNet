<Window
    x:Class="MaplestoryBotNet.Xaml.MacroRuneingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MaplestoryBotNet.Xaml"
    mc:Ignorable="d"
    Title="Runeing Window" 
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Width="600"
    Height="600"
    MaxHeight="600"
    MaxWidth="600"
    MinHeight="600"
    MinWidth="600"
    Topmost="True"
    Background="Black"
>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Xaml/Resources/ComboBoxResource.xaml"/>
                <ResourceDictionary Source="/Xaml/Resources/ButtonResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Viewbox Stretch="Fill">
        <Grid Background="Black" Height="530" Width="575" >
            <Rectangle Margin="5,31,5,283" Stroke="White">
            </Rectangle>
            <ListBox
                x:Name="RuneingPointsMacroListBox"
                Margin="213,54,15,329"
                Background="Black"
                Foreground="White"
                FontFamily="Courier New"
                SelectedIndex="0"
            >
                <ComboBox
                    x:Name="RuneingPointMacroComboBoxTemplate"
                    Width="275"
                    IsEditable="True"
                    FontSize="10"
                >
                    <ComboBoxItem Content="Wait {#} {#}"/>
                    <ComboBoxItem Content="Key press {{key}, ...} {#} {#}"/>
                    <ComboBoxItem Content="Key down {key}"/>
                    <ComboBoxItem Content="Key up {key}"/>
                </ComboBox>
            </ListBox>
            <Label
                Content="Macro commands:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="214,32,0,0"
                VerticalAlignment="Top"
                Width="128"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Label
                Content="Selected:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="16,32,0,0"
                VerticalAlignment="Top"
                Width="76"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold" RenderTransformOrigin="0.952,0.571" Height="23"
            />
            <ListBox
                x:Name="RuneingPointsListBox"
                Margin="16,55,371,336"
                Background="Black"
                Foreground="White"
                FontFamily="Courier New"
                SelectedIndex="0"
            >
                <ListBoxItem>
                    <Grid>
                        <TextBox
                            x:Name="RuneingSelectedPointTextBoxTemplate"
                            Margin="0,0,-113,0"
                            Background="Black"
                            Foreground="Lime"
                            FontFamily="Courier New"
                            TabIndex="5"
                            Height="22"
                        />
                    </Grid>
                </ListBoxItem>
            </ListBox>
            <Label
                Content="Point configuration:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,9,0,0"
                VerticalAlignment="Top"
                Width="159"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Label
                Content="Movement configuration:"
                FontFamily="Courier New"
                Margin="5,249,345,259"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Rectangle Margin="6,272,6,42" Stroke="White"/>
            <ComboBox
                x:Name="DirectionComboBox"
                IsEditable="False"
                FontSize="10"
                FontFamily="Courier New"
                Margin="17,458,438,50"
                Height="22"
            >
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Right"/>
            </ComboBox>
            <Button
                x:Name="SaveButton"
                Style="{StaticResource BottingButtonStyle}" 
                FontFamily="Courier New"
                Content="Save"
                HorizontalAlignment="Left"
                Margin="96,496,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Width="160"
                IsTabStop="False"
                Height="27"
            />
            <Button
                x:Name="LoadButton"
                Style="{StaticResource BottingButtonStyle}"
                FontFamily="Courier New"
                Content="Load"
                HorizontalAlignment="Left"
                Margin="317,496,0,0"
                Padding="2,2,2,2"
                VerticalAlignment="Top"
                Width="160"
                IsTabStop="False"
                Height="27"
            />
            <Label
                Content="Next frame:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,193,0,0"
                VerticalAlignment="Top"
                Width="108"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <TextBox
                x:Name="NextFrameTextBox"
                Margin="16,215,468,293"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="5"
                Height="22"
            />
            <Label
                Content="Radius:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="115,193,0,0"
                VerticalAlignment="Top"
                Width="116"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <TextBox
                x:Name="RadiusTextBox"
                Margin="118,215,371,293"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="5"
                Height="22"
            />
            <ListBox
                x:Name="RuneingMovementsListBox"
                Margin="17,297,371,116"
                Background="Black"
                Foreground="White"
                FontFamily="Courier New"
                SelectedIndex="0"
            >
                <ListBoxItem>
                    <Grid>
                        <TextBox
                            x:Name="RuneingSelectedMovementTextBoxTemplate"
                            Margin="0,0,-113,0"
                            Background="Black"
                            Foreground="Lime"
                            FontFamily="Courier New"
                            TabIndex="5"
                            Height="22"
                        />
                    </Grid>
                </ListBoxItem>
            </ListBox>
            <Label
                Content="Selected:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="16,275,0,0"
                VerticalAlignment="Top"
                Width="76"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
                Height="23"
            />
            <Label
                Content="Direction:"
                FontFamily="Courier New"
                Margin="14,437,453,73"
                Width="108"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Label
                Content="Distance:"
                FontFamily="Courier New"
                Margin="140,437,366,73"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <TextBox
                x:Name="DistanceTextBox"
                Margin="144,458,372,50"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                TabIndex="5"
                Height="22"
            />
            <ListBox
                x:Name="RuneingMovementsMacroListBox"
                Margin="214,297,15,86"
                Background="Black"
                Foreground="White"
                FontFamily="Courier New"
                SelectedIndex="0"
            >
                <ComboBox
                    x:Name="RuneingMovementComboBoxTemplate"
                    Width="275"
                    IsEditable="True"
                    FontSize="10"
                >
                    <ComboBoxItem Content="Wait {#} {#}"/>
                    <ComboBoxItem Content="Key press {{key}, ...} {#} {#}"/>
                    <ComboBoxItem Content="Key down {key}"/>
                    <ComboBoxItem Content="Key up {key}"/>
                </ComboBox>
            </ListBox>
            <Label
                Content="Macro commands:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="214,274,0,0"
                VerticalAlignment="Top"
                Width="128"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Button x:Name="MovementAddMacroCommandButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="+ Command"
                HorizontalAlignment="Left"
                Margin="214,455,0,0"
                VerticalAlignment="Top"
                Height="26"
                Width="101"
                FontFamily="Courier New"
            />
            <Button
                x:Name="MovementRemoveMacroCommandButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="- Command"
                HorizontalAlignment="Left"
                Margin="336,455,0,0"
                VerticalAlignment="Top"
                Height="26"
                Width="101"
                FontFamily="Courier New"
            />
            <Button
                Style="{StaticResource BottingButtonStyle}"
                x:Name="MovementClearMacroCommandsButton"
                Content="X Commands"
                HorizontalAlignment="Left"
                Margin="459,454,0,0"
                VerticalAlignment="Top"
                Height="26"
                Width="101"
                FontFamily="Courier New"
            />
            <Button
                x:Name="PointMacroAddCommandButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="+ Command"
                HorizontalAlignment="Left"
                Margin="213,212,0,0"
                VerticalAlignment="Top"
                Height="26"
                Width="101"
                FontFamily="Courier New"
            />
            <Button
                x:Name="PointMacroRemoveCommandButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="- Command"
                HorizontalAlignment="Left"
                Margin="335,212,0,0"
                VerticalAlignment="Top"
                Height="26"
                Width="101"
                FontFamily="Courier New"
            />
            <Button
                x:Name="PointMacroClearCommandsButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="X Commands"
                HorizontalAlignment="Left"
                Margin="458,211,0,0"
                VerticalAlignment="Top"
                Height="26"
                Width="101"
                FontFamily="Courier New"
            />
            <TextBox
                x:Name="RuneingSelectedFrameTextBox"
                Margin="446,4,5,504"
                VerticalContentAlignment="Center"
                Background="Black"
                Foreground="Wheat"
                Width="124"
                FontFamily="Courier New"
                TextAlignment="Center"
                TabIndex="5"
                Height="22"
            />
            <Label
                Content="Selected frame:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="336,3,0,0"
                VerticalAlignment="Top"
                Width="109"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Button
                x:Name="MovementAddMacroButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="+ Macro"
                Margin="19,418,472,93"
                Height="19"
                Width="84"
                FontFamily="Courier New"
            />
            <Button
                x:Name="MovementRemoveMacroButton"
                Style="{StaticResource BottingButtonStyle}"
                Content="- Macro"
                Margin="120,418,371,93"
                Height="19"
                Width="84"
                FontFamily="Courier New"
            />
        </Grid>
    </Viewbox>
</Window>
