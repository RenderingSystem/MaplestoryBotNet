<Window
    x:Class="MaplestoryBotNet.Xaml.MacroRuneingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:eo="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    xmlns:local="clr-namespace:MaplestoryBotNet.Xaml"
    mc:Ignorable="d"
    Title="Runeing Window" 
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Width="600"
    Height="400"
    MaxHeight="400"
    MaxWidth="600"
    MinHeight="400"
    MinWidth="600"
    Topmost="True"
    Background="Black"
>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Xaml/Resources/TabItemResource.xaml"/>
                <ResourceDictionary Source="/Xaml/Resources/ComboBoxResource.xaml"/>
                <ResourceDictionary Source="/Xaml/Resources/ButtonResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type eo:TabItem}" BasedOn="{StaticResource TabItemStyle}"/>
        </ResourceDictionary>
    </Window.Resources>

    <Viewbox Stretch="Fill">
        <Grid Background="Black" Height="353" Width="575">
            <TabControl>
                <TabItem Header="Points">
                    <Grid Background="Black">
                        <Rectangle Margin="5,24,5,55" Stroke="White"/>
                        <ListBox
                            x:Name="RuneingPointsMacroListBox"
                            Margin="213,47,15,96"
                            Background="Black"
                            Foreground="White"
                            FontFamily="Courier New"
                            SelectedIndex="0"
                        >
                            <ComboBox
                                x:Name="RuneingPointMacroComboBoxTemplate"
                                Width="275"
                                IsEditable="True"
                                FontSize="10"
                            >
                                <ComboBoxItem Content="Wait {#} {#}"/>
                                <ComboBoxItem Content="Key press {{key}, ...} {#} {#}"/>
                                <ComboBoxItem Content="Key down {key}"/>
                                <ComboBoxItem Content="Key up {key}"/>
                            </ComboBox>
                        </ListBox>
                        <Label
                            Content="Macro commands:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="214,25,0,0"
                            VerticalAlignment="Top"
                            Width="128"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <Label
                            Content="Selected:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="16,25,0,0"
                            VerticalAlignment="Top"
                            Width="76"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                            Height="23"
                        />
                        <ListBox
                            x:Name="RuneingPointsListBox"
                            Margin="16,48,371,108"
                            Background="Black"
                            Foreground="White"
                            FontFamily="Courier New"
                            SelectedIndex="0"
                        >
                            <ListBoxItem>
                                <Grid>
                                    <TextBox
                                        x:Name="RuneingSelectedPointTextBoxTemplate"
                                        Margin="0,0,-113,0"
                                        Background="Black"
                                        Foreground="Lime"
                                        FontFamily="Courier New"
                                        Height="22"
                                    />
                                </Grid>
                            </ListBoxItem>
                        </ListBox>
                        <Label
                            Content="Point configuration:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="5,2,0,0"
                            VerticalAlignment="Top"
                            Width="159"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <Button
                            x:Name="FramePointsSaveButton"
                            Style="{StaticResource BottingButtonStyle}" 
                            FontFamily="Courier New"
                            Content="Save"
                            HorizontalAlignment="Left"
                            Margin="118,282,0,0"
                            Padding="2,2,2,2"
                            VerticalAlignment="Top"
                            Width="160"
                            IsTabStop="False"
                            Height="27"
                        />
                        <Button
                            x:Name="FramePointsLoadButton"
                            Style="{StaticResource BottingButtonStyle}"
                            FontFamily="Courier New"
                            Content="Load"
                            HorizontalAlignment="Left"
                            Margin="305,282,0,0"
                            Padding="2,2,2,2"
                            VerticalAlignment="Top"
                            Width="160"
                            IsTabStop="False"
                            Height="27"
                        />
                        <Label
                            Content="Next frame:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="14,214,0,0"
                            VerticalAlignment="Top"
                            Width="108"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <TextBox
                            x:Name="NextFrameTextBox"
                            Margin="16,236,468,64"
                            Background="Black"
                            Foreground="Lime"
                            FontFamily="Courier New"
                            Height="22"
                        />
                        <Label
                            Content="Radius:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="115,214,0,0"
                            VerticalAlignment="Top"
                            Width="116"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <TextBox
                            x:Name="RadiusTextBox"
                            Margin="118,236,371,64"
                            Background="Black"
                            Foreground="Lime"
                            FontFamily="Courier New"
                            Height="22"
                        />
                        <Button
                            x:Name="PointMacroAddCommandButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="+ Command"
                            HorizontalAlignment="Left"
                            Margin="213,233,0,0"
                            VerticalAlignment="Top"
                            Height="26"
                            Width="101"
                            FontFamily="Courier New"
                        />
                        <Button
                            x:Name="PointMacroRemoveCommandButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="- Command"
                            HorizontalAlignment="Left"
                            Margin="335,233,0,0"
                            VerticalAlignment="Top"
                            Height="26"
                            Width="101"
                            FontFamily="Courier New"
                        />
                        <Button
                            x:Name="PointMacroClearCommandsButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="X Commands"
                            HorizontalAlignment="Left"
                            Margin="458,232,0,0"
                            VerticalAlignment="Top"
                            Height="26"
                            Width="101"
                            FontFamily="Courier New"
                        />
                    </Grid>
                </TabItem>
                <TabItem Header="Movements">
                    <Grid Background="Black">
                        <Label
                            Content="Movement configuration:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="5,2,0,0"
                            VerticalAlignment="Top"
                            Width="159"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <Rectangle Margin="5,24,5,55" Stroke="White"/>
                        <ComboBox
                            x:Name="DirectionComboBox"
                            IsEditable="False"
                            FontSize="10"
                            FontFamily="Courier New"
                            Margin="16,236,436,64"
                            Width="120"
                            Height="22"
                        >
                            <ComboBoxItem Content="Left"/>
                            <ComboBoxItem Content="Right"/>
                        </ComboBox>
                        <ListBox
                            x:Name="RuneingMovementsListBox"
                            Margin="16,48,371,137"
                            Background="Black"
                            Foreground="White"
                            FontFamily="Courier New"
                            SelectedIndex="0"
                        >
                            <ListBoxItem>
                                <Grid>
                                    <TextBox
                                        x:Name="RuneingSelectedMovementTextBoxTemplate"
                                        Margin="0,0,-113,0"
                                        Background="Black"
                                        Foreground="Lime"
                                        FontFamily="Courier New"
                                        Height="22"
                                    />
                                </Grid>
                            </ListBoxItem>
                        </ListBox>
                        <Label
                            Content="Selected:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="16,25,0,0"
                            VerticalAlignment="Top"
                            Width="76"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                            Height="23"
                        />
                        <TextBox
                            x:Name="DistanceTextBox"
                            Margin="141,235,371,64"
                            Background="Black"
                            Foreground="Lime"
                            FontFamily="Courier New"
                        />
                        <ListBox
                            x:Name="RuneingMovementsMacroListBox"
                            Margin="213,47,15,96"
                            Background="Black"
                            Foreground="White"
                            FontFamily="Courier New"
                            SelectedIndex="0"
                        >
                            <ComboBox
                                x:Name="RuneingMovementComboBoxTemplate1"
                                Width="275"
                                IsEditable="True"
                                FontSize="10"
                            >
                                <ComboBoxItem Content="Wait {#} {#}"/>
                                <ComboBoxItem Content="Key press {{key}, ...} {#} {#}"/>
                                <ComboBoxItem Content="Key down {key}"/>
                                <ComboBoxItem Content="Key up {key}"/>
                            </ComboBox>
                        </ListBox>
                        <Label
                            Content="Macro commands:"
                            FontFamily="Courier New"
                            HorizontalAlignment="Left"
                            Margin="214,25,0,0"
                            VerticalAlignment="Top"
                            Width="128"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <Button x:Name="MovementAddMacroCommandButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="+ Command"
                            HorizontalAlignment="Left"
                            Margin="213,233,0,0"
                            VerticalAlignment="Top"
                            Height="26"
                            Width="101"
                            FontFamily="Courier New"
                        />
                        <Button
                            x:Name="MovementRemoveMacroCommandButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="- Command"
                            HorizontalAlignment="Left"
                            Margin="335,233,0,0"
                            VerticalAlignment="Top"
                            Height="26"
                            Width="101"
                            FontFamily="Courier New"
                        />
                        <Button
                            Style="{StaticResource BottingButtonStyle}"
                            x:Name="MovementClearMacroCommandsButton"
                            Content="X Commands"
                            HorizontalAlignment="Left"
                            Margin="458,232,0,0"
                            VerticalAlignment="Top"
                            Height="26"
                            Width="101"
                            FontFamily="Courier New"
                        />
                        <Label
                            Content="Direction:"
                            FontFamily="Courier New"
                            Margin="13,214,483,86"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold" RenderTransformOrigin="0.5,0.5"
                        />
                        <Label
                            Content="Distance:"
                            FontFamily="Courier New"
                            Margin="138,214,359,84"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="Bold"
                        />
                        <Button
                            x:Name="MovementAddMacroButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="+ Macro"
                            Margin="16,190,472,108"
                            Width="84"
                            FontFamily="Courier New"
                        />
                        <Button
                            x:Name="MovementRemoveMacroButton"
                            Style="{StaticResource BottingButtonStyle}"
                            Content="- Macro"
                            Margin="117,190,371,108"
                            Width="84"
                            FontFamily="Courier New"
                        />
                        <Button
                            x:Name="FrameMovementsSaveButton"
                            Style="{StaticResource BottingButtonStyle}" 
                            FontFamily="Courier New"
                            Content="Save"
                            HorizontalAlignment="Left"
                            Margin="118,282,0,0"
                            Padding="2,2,2,2"
                            VerticalAlignment="Top"
                            Width="160"
                            IsTabStop="False"
                            Height="27"
                        />
                        <Button
                            x:Name="FrameMovementsLoadButton"
                            Style="{StaticResource BottingButtonStyle}"
                            FontFamily="Courier New"
                            Content="Load"
                            HorizontalAlignment="Left"
                            Margin="305,282,0,0"
                            Padding="2,2,2,2"
                            VerticalAlignment="Top"
                            Width="160"
                            IsTabStop="False"
                            Height="27"
                        />
                    </Grid>
                </TabItem>
            </TabControl>
            <TextBox
                x:Name="RuneingSelectedFrameTextBox"
                Margin="446,3,5,328"
                VerticalContentAlignment="Center"
                Background="Black"
                Foreground="Wheat"
                Width="124"
                FontFamily="Courier New"
                TextAlignment="Center"
                Height="22"
                BorderBrush="#FFABADB3"
            />
            <Label
                Content="Selected frame:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="336,3,0,0"
                VerticalAlignment="Top"
                Width="109"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
        </Grid>
    </Viewbox>
</Window>
