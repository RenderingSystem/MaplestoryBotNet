                Width="182"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Workspace id:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,51,0,0"
                VerticalAlignment="Top"
                Width="102"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="API key:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,72,0,0"
                VerticalAlignment="Top"
                Width="102"
                FontSize="10"
                Foreground="White"
            />
