                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,251,0,0"
                VerticalAlignment="Top"
                Width="45"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Down:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
