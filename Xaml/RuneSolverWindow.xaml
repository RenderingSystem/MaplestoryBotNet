                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="JsonTagXTextBox"
                Margin="50,145,184,138"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
