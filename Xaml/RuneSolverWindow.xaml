            <TextBox
                x:Name="ArrowRightTextBox"
                Margin="50,251,184,32"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowDownTextBox"
                Margin="50,273,184,10"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Frame
                Margin="121,122,10,10"
                BorderBrush="White"
                BorderThickness="1"
            />
            <TextBlock
                x:Name="OutputFormatTextBlock"
                HorizontalAlignment="Left"
                Height="154"
                Margin="128,129,0,0"
                TextWrapping="Wrap"
                FontSize="8"
                FontFamily="Courier New"
                Foreground="Lime"
                Text="TextBlock"
                VerticalAlignment="Top"
                Width="155"
            />
