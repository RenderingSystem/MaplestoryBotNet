<Window
    x:Class="MaplestoryBotNet.AilmentsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MaplestoryBotNet"
    mc:Ignorable="d"
    Title="Fruity Pebbles"
    Height="400"
    Width="350"
    MaxHeight="400"
    MaxWidth="350"
    MinHeight="400"
    MinWidth="350"
    Background="Black"
    WindowStartupLocation="CenterScreen"
    SizeToContent="WidthAndHeight"
    ResizeMode="NoResize"
>
    <Viewbox Stretch="Fill">
        <Grid Height="400" Width="350">
            <Grid
                x:Name="AilmentsImageGrid"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Height="150"
                Width="150"
                Margin="10,30,0,0"
            >
            </Grid>
            <Frame
                BorderBrush="White"
                BorderThickness="1"
                Margin="10,30,190,220"
            />
            <ListBox
                x:Name="AilmentsListBox"
                Margin="10,185,190,15"
                Background="#FF202020"
                FontFamily="Courier New"
            >
                <ListBoxItem>
                    <StackPanel
                        x:Name="AilmentsCheckboxTemplate"
                        Orientation="Horizontal"
                    >
                        <CheckBox/>
                        <TextBlock
                            Text="Lorem Ipsum"
                            Margin="5,0,0,0"
                            Foreground="#FFFFFFFF"
                            VerticalAlignment="Bottom"
                        />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
            <Label
                Content="Ailments:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,2,0,0"
                VerticalAlignment="Top"
                Width="159"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Label
                Content="Configuration:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="160,2,0,0"
                VerticalAlignment="Top"
                Width="159"
                Foreground="White"
                FontSize="11"
                FontWeight="Bold"
            />
            <Frame
                BorderBrush="White"
                BorderThickness="1"
                Content="Frame"
                Margin="164,30,10,15"
            />
            <StackPanel
                Orientation="Vertical"
                Margin="165,30,10,14"
            >
                <Grid Height="50">
                    <Label
                        Content="Macro delay:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                    />
                    <TextBox
                        x:Name="MacroDelayTextBox"
                        Margin="4,23,57,5"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                        />
                </Grid>
                <Grid Height="50">
                    <Label
                        Content="Check delay:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                    />
                    <TextBox
                        x:Name="CheckDelayTextBox"
                        Margin="4,23,57,5"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                    />
                </Grid>
                <Grid Height="50">
                    <Label
                        Content="Detect threshold:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                    />
                    <TextBox
                        x:Name="DetectThresholdTextBox"
                        Margin="4,23,58,5"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                    />
                </Grid>
                <Grid Height="50">
                    <Label
                        Content="All-cure key:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                    />
                    <TextBox
                        x:Name="AllCureKeyTextBox"
                        Margin="4,23,57,5"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                        />
                </Grid>
                <Grid Height="150">
                    <Label
                        Content="Detect rectangle:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                    />
                    <Label
                        Content="Left:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        Margin="7,25,0,0" RenderTransformOrigin="0.523,-0.175"
                    />
                    <TextBox
                        x:Name="DetectRectangleLeft"
                        Margin="65,25,11,103"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                        />
                    <Label
                        Content="Top:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        Margin="7,50,0,0" RenderTransformOrigin="0.523,-0.175"
                    />
                    <TextBox
                        x:Name="DetectRectangleTop"
                        Margin="65,50,11,78"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                        />
                    <Label
                        Content="Right:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        Margin="7,74,0,0" RenderTransformOrigin="0.523,-0.175"
                    />
                    <TextBox
                        x:Name="DetectRectangleRight"
                        Margin="65,75,11,53"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                        />
                    <Label
                        Content="Bottom:"
                        FontFamily="Courier New"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="White"
                        FontSize="11"
                        Margin="7,99,0,0" RenderTransformOrigin="0.523,-0.175"
                    />
                    <TextBox
                        x:Name="DetectRectangleBottom"
                        Margin="66,100,11,28"
                        Background="Black"
                        Foreground="Lime"
                        FontFamily="Courier New"
                        TabIndex="5"
                    />
                </Grid>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
