<Window
    x:Class="MaplestoryBotNet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MaplestoryBotNet"
    mc:Ignorable="d"
    Title="Microsoft Teams"
    Height="600"
    Width="800"
    MaxHeight="600"
    MaxWidth="800"
    MinHeight="600"
    MinWidth="800"
    Background="Black"
    WindowStartupLocation="CenterScreen"
    SizeToContent="WidthAndHeight"
    ResizeMode="NoResize"
>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem x:Name="ExitMenuItem" Header="Exit"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Edit">
                <MenuItem x:Name="PotionsMenuItem" Header="Consumables"/>
                <MenuItem x:Name="AilmentsMenuItem" Header="Ailments"/>
                <MenuItem x:Name="RuneSolverMenuItem" Header="Rune solver"/>
            </MenuItem>
            <Separator/>
            <MenuItem x:Name="MacroMenuItem" Header="Botting"/>
            <Separator/>
            <Separator/>
            <MenuItem x:Name="StartMenuItem" Header="Start!"/>
        </Menu>
        <Grid>
            <Image
                x:Name="ImageView"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Stretch="Uniform"
            />
            <TextBlock
                x:Name="ResettingText"
                Text="Resetting"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
            <TextBlock
                x:Name="BottingText"
                Text="Botting"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
            <TextBlock
                x:Name="RuneingText"
                Text="Runeing"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
            <TextBlock
                x:Name="SolvingText"
                Text="Solving"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
            <TextBlock
                x:Name="SolvedCheckText"
                Text="Solved check"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
            <TextBlock
                x:Name="CashShopText"
                Text="Cash shop"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
            <TextBlock
                x:Name="IdleText"
                Text="Idle"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
            />
            <TextBlock
                x:Name="AilmentsText"
                Text="Ailments"
                Margin="0,510,10,0"
                FontFamily="Courier New"
                Foreground="#FF00FF00"
                HorizontalAlignment="Right"
                FontSize="20"
                Visibility="Hidden"
            />
        </Grid>
    </DockPanel>
</Window>
