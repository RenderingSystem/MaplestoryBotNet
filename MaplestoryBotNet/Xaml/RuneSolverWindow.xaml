<Window
    x:Class="MaplestoryBotNet.Xaml.RuneSolverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MaplestoryBotNet.Xaml"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:eo="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    mc:Ignorable="d"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Title="Fruit Loops"
    Width="300"
    Height="300"
    MaxHeight="300"
    MaxWidth="300"
    MinHeight="300"
    MinWidth="300"
    Background="Black"
>
    <Viewbox Stretch="Fill">
        <Grid Width="300" Height="300">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="203*"/>
                <ColumnDefinition Width="97*"/>
            </Grid.ColumnDefinitions>
            <Label
                Content="Rune solving configuration:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,7,0,0"
                VerticalAlignment="Top"
                Width="182"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="IP address:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,30,0,0"
                VerticalAlignment="Top"
                Width="102"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Port:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,51,0,0"
                VerticalAlignment="Top"
                Width="102"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Left:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="6,145,0,0"
                VerticalAlignment="Top"
                Width="44"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Up:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="7,168,0,0"
                VerticalAlignment="Top"
                Width="43"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Right:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="6,191,0,0"
                VerticalAlignment="Top"
                Width="45"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Down:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="6,211,0,0"
                VerticalAlignment="Top"
                Width="43"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="IPAddressTextbox"
                Margin="117,32,18,252"
                Width="165"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                FontSize="9" Grid.ColumnSpan="2"
            />
            <TextBox
                x:Name="PortTextBox"
                Margin="117,53,18,230"
                Width="165"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                FontSize="9" Grid.ColumnSpan="2"
            />
            <TextBox
                x:Name="ArrowLeftTextBox"
                Margin="51,147,94,136"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowUpTextBox"
                Margin="51,169,94,114"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowRightTextBox"
                Margin="51,191,94,92"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowDownTextBox"
                Margin="51,213,94,70"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Frame
                Margin="113,122,7,9"
                BorderBrush="White"
                BorderThickness="1" Grid.ColumnSpan="2"
            />
            <TextBlock
                x:Name="OutputFormatTextBlock"
                HorizontalAlignment="Left"
                Height="155"
                Margin="120,129,0,0"
                TextWrapping="Wrap"
                FontSize="8"
                FontFamily="Courier New"
                Foreground="Lime"
                Text="TextBlock"
                VerticalAlignment="Top"
                Width="168" Grid.ColumnSpan="2"
            />
            <Label
                Content="Tag:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="7,122,0,0"
                VerticalAlignment="Top"
                Width="44"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="ClassTagTextBox"
                Margin="51,124,94,159"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Label
                Content="Route:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,73,0,0"
                VerticalAlignment="Top"
                Width="102"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="RouteTextBox"
                Margin="117,75,18,208"
                Width="165"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                FontSize="9" Grid.ColumnSpan="2"
            />
            <Label
                Content="Prediction JSON tags:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="6,97,0,0"
                VerticalAlignment="Top"
                Width="143"
                FontSize="10"
                Foreground="White"
            />
        </Grid>
    </Viewbox>
</Window>
