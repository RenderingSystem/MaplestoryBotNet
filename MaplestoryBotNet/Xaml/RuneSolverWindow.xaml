<Window
    x:Class="MaplestoryBotNet.Xaml.RuneSolverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MaplestoryBotNet.Xaml"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:eo="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    mc:Ignorable="d"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Title="Fruit Loops"
    Height="300"
    MaxHeight="300"
    MinHeight="300"
    Width="250"
    MaxWidth="250"
    MinWidth="250"
    Background="Black"
>
    <Viewbox Stretch="Fill">
        <Grid Width="250" Height="300">
            <Label
                Content="Rune solving configuration:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,7,0,0"
                VerticalAlignment="Top"
                Width="182"
                FontSize="10"
                Foreground="White" FontWeight="Bold"
            />
            <Label
                Content="IP address:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,30,0,0"
                VerticalAlignment="Top"
                Width="77"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Port:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,51,0,0"
                VerticalAlignment="Top"
                Width="77"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Left:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,137,0,0"
                VerticalAlignment="Top"
                Width="44"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Up:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="6,156,0,0"
                VerticalAlignment="Top"
                Width="43"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Right:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="4,175,0,0"
                VerticalAlignment="Top"
                Width="45"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Down:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="6,194,0,0"
                VerticalAlignment="Top"
                Width="43"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="IPAddressTextbox"
                Margin="96,32,10,252"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="PortTextBox"
                Margin="96,53,10,230"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowLeftTextBox"
                Margin="49,140,138,143"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowUpTextBox"
                Margin="49,159,138,124"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowRightTextBox"
                Margin="49,177,138,106"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="ArrowDownTextBox"
                Margin="49,196,138,87"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Frame
                Margin="10,219,10,5"
                BorderBrush="White"
                BorderThickness="1"
            />
            <TextBlock
                x:Name="OutputFormatTextBlock"
                HorizontalAlignment="Center"
                Height="68"
                Margin="0,223,0,0"
                TextWrapping="Wrap"
                FontSize="8"
                FontFamily="Courier New"
                Foreground="Lime"
                Text="TextBlock"
                VerticalAlignment="Top"
                Width="223"
            />
            <Label
                Content="Tag:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,119,0,0"
                VerticalAlignment="Top"
                Width="44"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="ClassTagTextBox"
                Margin="49,120,138,163"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Label
                Content="Route:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="14,73,0,0"
                VerticalAlignment="Top"
                Width="77"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="RouteTextBox"
                Margin="96,75,10,208"
                Background="Black"
                Foreground="LightYellow"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Label
                Content="JSON tags:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="5,95,0,0"
                VerticalAlignment="Top"
                Width="73"
                FontSize="10"
                Foreground="White" FontWeight="Bold"
            />
            <Label
                Content="Rune interact:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="117,157,0,0"
                VerticalAlignment="Top"
                Width="102"
                FontSize="10"
                Foreground="White"
                FontWeight="Bold"
                Height="20"
            />
            <TextBox
                x:Name="RuneRetriesTextBox"
                Margin="177,196,10,87"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Label Content="Key:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="118,175,0,0"
                VerticalAlignment="Top"
                Width="44"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Cash shop:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="118,95,0,0"
                VerticalAlignment="Top"
                Width="70"
                FontSize="10"
                Foreground="White"
                FontWeight="Bold"
            />
            <Label Content="Key:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="118,119,0,0"
                VerticalAlignment="Top"
                Width="43"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="CashShopKey"
                Margin="177,120,10,163"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <TextBox
                x:Name="CashShopTimeout"
                Margin="177,140,10,143"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
            <Label Content="Timeout:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="118,137,0,0"
                VerticalAlignment="Top"
                Width="58"
                FontSize="10"
                Foreground="White"
            />
            <Label
                Content="Retries:"
                FontFamily="Courier New"
                HorizontalAlignment="Left"
                Margin="118,194,0,0"
                VerticalAlignment="Top"
                Width="58"
                FontSize="10"
                Foreground="White"
            />
            <TextBox
                x:Name="InteractKeyTextBox"
                Margin="177,177,10,106"
                Background="Black"
                Foreground="Lime"
                FontFamily="Courier New"
                FontSize="9"
            />
        </Grid>
    </Viewbox>
</Window>
